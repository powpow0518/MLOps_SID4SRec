# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Absolute path to the project root (used by Docker Compose for volume mounts)
# Windows example: E:/demo/project_MLOps
# Linux/Mac example: /home/user/project_MLOps
MLOPS_PROJECT_DIR=/path/to/project_MLOps

# Google Gemini API key (used by the RAG /explain endpoint)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model ID to use for RAG explanation
GEMINI_MODEL=models/gemini-2.5-flash

# PostgreSQL credentials (optional — defaults are shown below)
# POSTGRES_USER=mlops
# POSTGRES_PASSWORD=mlops
# POSTGRES_DB=mlops

# Grafana admin password (optional — default: admin)
# GRAFANA_PASSWORD=admin
